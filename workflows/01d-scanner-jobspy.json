      "id": "675344f6-4405-4a72-bba3-78a719413b60",
      "name": "Get Search Queries",
      "type": "n8n-nodes-base.airtable",
      "typeVersion": 2.1,
      "position": [
        -848,
        -240
      ],
      "alwaysOutputData": true,
