    {
      "parameters": {
        "jsCode": "// Deduplicate parsed jobs against existing Pipeline records\n// Same logic as Workflows 1a, 1b, 1c\n\nconst parsedJobs = $('Parse & Filter Jobs').all().filter(item => !item.json._empty);\nconst existingRecords = $('Get Existing Job IDs').all();\n\nconst existingIds = new Set();\nfor (const record of existingRecords) {\n  let jobId = null;\n  if (record.json.fields && record.json.fields['Job ID']) {\n    jobId = record.json.fields['Job ID'];\n  } else if (record.json['Job ID']) {\n    jobId = record.json['Job ID'];\n  }\n  if (jobId) existingIds.add(jobId);\n}\n\nconst netNew = parsedJobs.filter(item => !existingIds.has(item.json.jobId));\n\n// Safety brake: cap at 100 new records per run\nif (netNew.length > 100) {\n  throw new Error(`Safety brake: ${netNew.length} net-new jobs exceeds 100 limit. Review query config or increase cap.`);\n}\n\nif (netNew.length === 0) {\n  return [{ json: { _empty: true, _message: `${parsedJobs.length} jobs found, all already in Pipeline` } }];\n}\n\nreturn netNew;"
      },
