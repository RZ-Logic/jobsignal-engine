    {
      "parameters": {
        "jsCode": "// Build the batch payload for the JobSpy sidecar from Airtable Search Queries rows\n\nconst items = $input.all();\nconst queries = [];\nconst queryMeta = []; // Track record IDs for updating Last Run later\n\nfor (const item of items) {\n  const row = item.json.fields || item.json;\n  const recordId = item.json.id || null;\n  \n  // Skip rows without a query string\n  const queryString = row['Query String'];\n  if (!queryString) continue;\n  \n  // Parse JobSpy Sites (comma-separated string to array)\n  const sitesRaw = row['JobSpy Sites'] || 'indeed,linkedin';\n  const sites = sitesRaw.split(',').map(s => s.trim().toLowerCase()).filter(s => s.length > 0);\n  \n  // Title keywords per query\n  const titleKeywords = row['Title Keywords'] || '';\n  \n  queries.push({\n    search_term: queryString,\n    location: row['Location'] || '',\n    sites: sites,\n    country_indeed: row['Country Filter'] || 'Canada',\n    hours_old: row['Hours Old'] || 72,\n    results_wanted: row['Results Wanted'] || 50,\n    source_tag: row['Source Tag'] || '',\n    description_format: 'markdown',\n    linkedin_fetch_description: true,\n    title_keywords: titleKeywords\n  });\n  \n  queryMeta.push({\n    recordId: recordId,\n    queryName: row['Query'] || row['Query Name'] || queryString\n  });\n}\n\nif (queries.length === 0) {\n  return [{ json: { _empty: true, _message: 'No enabled JobSpy Search Queries found' } }];\n}\n\nreturn [{ json: { queries, queryMeta, queryCount: queries.length } }];"
      },
      "id": "ce950adf-7ce4-4dc8-a402-e34704260e68",
      "name": "Build Batch Payload",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -544,
        -240
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://jobspy-scanner:3457/batch",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ queries: $json.queries }) }}",
        "options": {
          "timeout": 120000
        }
      },
      "id": "8d3de140-dc47-4532-96d7-36a42daa2ee2",
      "name": "Call JobSpy Scanner",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        -176,
        -240
      ],
      "retryOnFail": true,
      "maxTries": 2,
      "waitBetweenTries": 5000,
      "alwaysOutputData": true,
      "continueOnFail": true
    },
    {
      "parameters": {
        "jsCode": "// Parse JobSpy batch response into individual job items\n// Apply per-query title keyword filter, geography filter, and generate FNV-1a Job IDs\n\nconst response = $input.first().json;\n\nif (!response.success) {\n  return [{ json: { _empty: true, _error: response.error || 'JobSpy batch call failed' } }];\n}\n\n// Get the original queries with their per-query title keywords\nconst batchPayload = $('Build Batch Payload').first().json;\nconst originalQueries = batchPayload.queries || [];\n\n// Geography filter — same pattern as Workflows 1a/1b/1c\n// TODO: Read from Profile.Target Geography in v1.1\nconst userGeographies = ['Canada', 'Remote Global', 'Remote North America'];\n\nconst GEO_CONFIG = {\n  'Canada': {\n    substrings: ['canada', 'toronto', 'vancouver', 'montreal', 'ottawa', 'calgary', 'mississauga', 'edmonton', 'waterloo', 'quebec', 'ontario', 'british columbia', 'alberta']\n  },\n  'USA': {\n    substrings: ['united states', 'usa', 'new york', 'san francisco', 'los angeles', 'seattle', 'chicago', 'austin', 'boston', 'denver']\n  },\n  'Remote Global': {\n    substrings: ['remote', 'worldwide', 'global', 'anywhere']\n  },\n  'Remote North America': {\n    substrings: ['remote north america', 'remote - north america', 'remote na', 'remote us/canada', 'remote us and canada']\n  }\n};\n\nconst allowedSubstrings = new Set();\nfor (const geo of userGeographies) {\n  const cfg = GEO_CONFIG[geo];\n  if (cfg) {\n    cfg.substrings.forEach(s => allowedSubstrings.add(s));\n  }\n}\n\nconst matchesGeography = (locationStr, isRemote) => {\n  if (!locationStr || locationStr === 'Not specified') {\n    if (isRemote) return true;\n    return true; // Let unspecified through, Evaluator will filter\n  }\n  const loc = locationStr.toLowerCase();\n  for (const sub of allowedSubstrings) {\n    if (loc.includes(sub)) return true;\n  }\n  return false;\n};\n\n// FNV-1a hash — same as all other scanner workflows\nconst fnv1aHash = (str) => {\n  let hash = 0x811c9dc5;\n  for (let i = 0; i < str.length; i++) {\n    hash ^= str.charCodeAt(i);\n    hash = Math.imul(hash, 0x01000193);\n  }\n  return (hash >>> 0).toString(16).padStart(8, '0');\n};\n\nconst siteToSource = {\n  'indeed': 'Indeed',\n  'linkedin': 'LinkedIn',\n  'zip_recruiter': 'ZipRecruiter',\n  'glassdoor': 'Glassdoor',\n  'google': 'Google Jobs'\n};\n\nconst allJobs = [];\nconst seen = new Set();\nlet rawTotal = 0;\nlet geoFiltered = 0;\nlet titleFiltered = 0;\n\nconst queryResults = response.query_results || [];\n\nfor (let qi = 0; qi < queryResults.length; qi++) {\n  const queryResult = queryResults[qi];\n  const sourceTag = queryResult.source_tag || '';\n  const searchTerm = queryResult.search_term || '';\n  \n  // Get per-query title keywords from the original query config\n  const origQuery = originalQueries[qi] || {};\n  const titleKeywordsRaw = origQuery.title_keywords || '';\n  const titleKeywords = titleKeywordsRaw\n    .split(',')\n    .map(k => k.trim().toLowerCase())\n    .filter(k => k.length > 0);\n  \n  for (const job of (queryResult.jobs || [])) {\n    rawTotal++;\n    if (!job.title || !job.job_url) continue;\n    \n    // Per-query title keyword filter\n    if (titleKeywords.length > 0) {\n      const t = job.title.toLowerCase();\n      if (!titleKeywords.some(kw => t.includes(kw))) {\n        titleFiltered++;\n        continue;\n      }\n    }\n    \n    const location = job.location || 'Not specified';\n    if (!matchesGeography(location, job.is_remote)) {\n      geoFiltered++;\n      continue;\n    }\n    \n    const applyLink = job.job_url_direct || job.job_url;\n    const company = job.company || 'Unknown';\n    \n    const hashInput = `${job.title}|${company}|${applyLink}`;\n    const jobId = fnv1aHash(hashInput) + '-spy';\n    \n    if (seen.has(jobId)) continue;\n    seen.add(jobId);\n    \n    const source = siteToSource[job.site] || job.site || 'Indeed';\n    \n    let salaryInfo = '';\n    if (job.salary_min && job.salary_max) {\n      const currency = job.salary_currency || 'USD';\n      const interval = job.salary_interval || 'yearly';\n      salaryInfo = `${currency} ${Math.round(job.salary_min).toLocaleString()} - ${Math.round(job.salary_max).toLocaleString()} (${interval})`;\n    } else if (job.salary_min) {\n      salaryInfo = `${job.salary_currency || 'USD'} ${Math.round(job.salary_min).toLocaleString()}+`;\n    }\n    \n    let description = job.description || '';\n    if (description.length > 50000) {\n      description = description.substring(0, 50000) + '\\n\\n[Description truncated]';\n    }\n    \n    allJobs.push({\n      json: {\n        jobId,\n        jobTitle: job.title,\n        company,\n        location,\n        applyLink,\n        jobDescription: description,\n        source,\n        sourceQuery: searchTerm,\n        sourceTag,\n        discoveryDate: new Date().toISOString().split('T')[0],\n        salaryInfo,\n        isRemote: job.is_remote || false\n      }\n    });\n  }\n}\n\nif (allJobs.length === 0) {\n  return [{ json: { _empty: true, _message: `JobSpy: ${rawTotal} raw, ${titleFiltered} title-filtered, ${geoFiltered} geo-filtered, 0 survived` } }];\n}\n\nreturn allJobs;"
      },
